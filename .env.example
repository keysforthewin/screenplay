# Discord
DISCORD_BOT_TOKEN=
MOVIE_CHANNEL_ID=322822813549461535

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
# Per-turn output token cap. 4096 is too tight for routine multi-tool turns
# (narrative + create_beat + update_character) and causes silent tool-call
# truncation. 16000 leaves comfortable headroom; you only pay for tokens
# actually generated.
ANTHROPIC_MAX_TOKENS=16000

# Google Gemini ("Nano Banana" image generation). Optional — if unset,
# generate_image returns a friendly error and other tools work normally.
GEMINI_API_KEY=

# Vertex AI service account JSON file on the HOST. docker-compose bind-mounts
# this path to /secrets/alexa2.json inside the container. If you use Vertex,
# also set GOOGLE_APPLICATION_CREDENTIALS=/secrets/alexa2.json (and
# GEMINI_VERTEX_PROJECT) below. Leave unset for local dev without Vertex —
# defaults to /dev/null so the bind mount stays valid.
GOOGLE_APPLICATION_CREDENTIALS_HOST_PATH=
GOOGLE_APPLICATION_CREDENTIALS=
GEMINI_VERTEX_PROJECT=

# TheMovieDB (TMDB) v4 Read Access Token. Optional — if unset, the tmdb_*
# tools return a friendly error and other tools work normally.
TMDB_READ_ACCESS_TOKEN=

# Tavily web search API. Optional — if unset, the tavily_* tools return a
# friendly error and other tools work normally.
TAVILY_API_KEY=

# Semantic search (RAG). Set VOYAGE_API_KEY to enable; the bot uses Voyage
# for embeddings (Anthropic-recommended). ChromaDB runs as a docker-compose
# service and the bot reaches it automatically — no CHROMA_URL needed for
# either docker-compose mode or local dev (defaults to http://localhost:8599,
# which is what `docker compose up -d chroma` publishes on the host).
# If Chroma isn't running, screenplay_search returns a friendly fallback
# and the rest of the bot works normally.
VOYAGE_API_KEY=
# VOYAGE_MODEL=voyage-3         # change embedding model
# CHROMA_URL=                   # override only for non-default Chroma host
# CHROMA_PORT=8599              # host port published by the chroma service
# CHROMA_COLLECTION=screenplay  # override only if running multiple projects on one Chroma
# RAG_DEBOUNCE_MS=1000          # debounce window for live reindexing
# RAG_MESSAGE_WINDOW=5000       # most-recent N messages kept indexed per channel
# RAG_DEFAULT_K=8               # default top-k for screenplay_search
# RAG_PRUNE_EVERY_N=100         # run message-window prune every N inserts

# MongoDB
MONGO_URI=mongodb://mongo:27017
MONGO_DB=screenplay

# Optional
LOG_LEVEL=info
PDF_EXPORT_DIR=/data/exports

# Web server (PDF download fallback). The bot starts an Express server on WEB_PORT
# and posts a download link alongside the Discord PDF attachment. WEB_PUBLIC_BASE_URL
# is what the link uses; if unset the link defaults to http://localhost:${WEB_PORT}.
WEB_PORT=3000
WEB_PUBLIC_BASE_URL=

# Hocuspocus collaborative editing WebSocket server.
# 3001 is held by Windows IP Helper service in this WSL2 setup, so use 3010.
# HOCUSPOCUS_PUBLIC_URL is what the SPA's /api/info hands the browser; must be
# reachable from the browser (e.g. ws://localhost:3010 for local dev).
HOCUSPOCUS_PORT=3010
HOCUSPOCUS_PUBLIC_URL=ws://localhost:3010

# Deploy target for ./deploy.sh — user@host:/absolute/path on the production box
# where rsync will upload the source and where 'docker compose' will run.
# Only used by the deploy script; the bot itself ignores this.
SSH_PATH=
