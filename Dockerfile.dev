# Dev image used by both the `bot` and `web` services in
# docker-compose.dev.yml. Source is bind-mounted at runtime; we just need a
# node + alpine image with the full dependency tree (including dev deps so
# vitest, vite, and friends are available).
FROM node:22-alpine
WORKDIR /app
RUN apk add --no-cache mongodb-tools curl
COPY package.json package-lock.json* ./
RUN npm ci
RUN mkdir -p /data/exports /data/backups
ENV PDF_EXPORT_DIR=/data/exports
ENV BACKUP_DIR=/data/backups
EXPOSE 3000 3010 5173
# Default command — overridden per-service in compose.
CMD ["node", "--watch", "src/index.js"]
